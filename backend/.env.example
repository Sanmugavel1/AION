# =============================================================================
# AION - Artificial Intelligence Organizational Nervous System
# Environment Configuration (lightweight local/dev stack)
# =============================================================================

# Application
APP_NAME=AION
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_V1_PREFIX=/api/v1
ALLOWED_HOSTS=["*"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Server
HOST=0.0.0.0
PORT=8001
WORKERS=4

# Database — SQLite (file-based, no server needed)
DATABASE_URL=sqlite+aiosqlite:///./data/aion.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Graph Store — embedded NetworkX graph (replaces Neo4j)
GRAPH_STORE_PATH=./data/graph_store.json

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM — pick one provider. Groq's OpenAI-compatible API is the default;
# leave GROQ_API_KEY blank to run in deterministic-fallback mode (no LLM
# calls, real-data summaries instead of AI-generated narrative).
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Knowledge Decay
KNOWLEDGE_DECAY_THRESHOLD_DAYS=90
KNOWLEDGE_CONFLICT_SIMILARITY_THRESHOLD=0.85
KNOWLEDGE_DUPLICATE_SIMILARITY_THRESHOLD=0.95

# OII Computation
OII_COMPUTATION_INTERVAL_HOURS=24
BOARD_REPORT_DAY=monday
BOARD_REPORT_HOUR=8

# Integrations (optional connectors — leave blank if unused)
SLACK_BOT_TOKEN=
GITHUB_TOKEN=
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
CONFLUENCE_URL=
GOOGLE_CREDENTIALS_FILE=google_credentials.json
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# Monitoring
PROMETHEUS_ENABLED=true
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json
